<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 相机预览层 -->
    <include
        android:id="@+id/camera_layer"
        layout="@layout/camera_preview"
        android:visibility="gone" />

    <!-- 祝福发送伪装层 -->
    <include
        android:id="@+id/blessing_layer"
        layout="@layout/layout_blessing"
        android:visibility="gone" />

    <!-- 表情包卡片层 -->
    <LinearLayout
        android:id="@+id/sticker_cards_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F5F5F5">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginTop="24dp">

        <TextView
            android:id="@+id/btn_back_sticker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← 返回"
            android:textSize="14sp"
            android:textColor="#666666"
            android:padding="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="你居然真的进来了！"
            android:textSize="22sp"
            android:textColor="#FFD740"
            android:textStyle="bold"
            android:gravity="center" />

        <View android:layout_width="48dp" android:layout_height="1dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="既然都进来了，那就…做点什么吧 😏"
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:paddingHorizontal="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical|center_horizontal">

            <!-- 1. 制作表情包 → 拿相机 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_selfie"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="1dp"
                app:strokeColor="#44FFB3C1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <TextView android:layout_width="44dp" android:layout_height="44dp"
                        android:text="🤳" android:textSize="28sp" android:gravity="center" />

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="制作表情包" android:textSize="17sp" android:textColor="#333333" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="AI 智能捕捉你的可爱瞬间，生成专属表情" android:textSize="12sp"
                            android:textColor="#666666" android:layout_marginTop="3dp" />
                    </LinearLayout>

                    <ProgressBar android:id="@+id/progress_selfie"
                        android:layout_width="22dp" android:layout_height="22dp"
                        android:indeterminateTint="#FF6B9D" android:visibility="gone" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▶" android:textSize="22sp" android:textColor="#FFB3C1" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. 为TA发送祝福 → 获取联系人/短信/通话记录 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_blessing"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp" app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF" app:strokeWidth="1dp" app:strokeColor="#44FF6B6B">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="18dp" android:gravity="center_vertical">
                    <TextView android:layout_width="44dp" android:layout_height="44dp"
                        android:text="💌" android:textSize="28sp" android:gravity="center" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="为TA发送祝福" android:textSize="17sp" android:textColor="#333333" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="自动提醒重要节日，帮你送出暖心祝福" android:textSize="12sp"
                            android:textColor="#666666" android:layout_marginTop="3dp" />
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▶" android:textSize="22sp" android:textColor="#FF6B6B" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="选择功能开始制作吧 ✨"
        android:textSize="12sp" android:textColor="#999999"
        android:layout_gravity="center" android:padding="16dp" />
    </LinearLayout>

</FrameLayout>
