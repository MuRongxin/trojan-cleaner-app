<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_game"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/starry_bg"
    android:visibility="invisible">

    <!-- 游戏页星空背景（普通 View，避免 GLSurfaceView 初始化黑帧） -->
    <com.shortvideocleaner.app.GameStarryView
        android:id="@+id/starry_game_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 菜单滚动区 -->
    <ScrollView
        android:id="@+id/menu_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- 标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="小游戏乐园"
                android:textSize="28sp"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:layout_marginTop="40dp"
                android:shadowColor="#80FFD700"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="16" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="和你一起玩的每一刻都很开心"
                android:textSize="14sp"
                android:textColor="#CCDDAAFF"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp" />

            <!-- 爱心点击游戏 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_heart_game"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#2A1A3E"
                app:strokeWidth="1dp"
                app:strokeColor="#44FFB3C1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="💕"
                        android:textSize="32sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="爱心点击"
                            android:textSize="18sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="点击飘落的爱心，收集满满的爱"
                            android:textSize="13sp"
                            android:textColor="#99FFFFFF"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶"
                        android:textSize="24sp"
                        android:textColor="#FFB3C1" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 烟花秀 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_firework_game"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#1A2A3E"
                app:strokeWidth="1dp"
                app:strokeColor="#4487CEEB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="🎆"
                        android:textSize="32sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="烟花秀"
                            android:textSize="18sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="点击屏幕放烟花，为你绽放绚烂"
                            android:textSize="13sp"
                            android:textColor="#99FFFFFF"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶"
                        android:textSize="24sp"
                        android:textColor="#87CEEB" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 摇一摇 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_shake_game"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#2A2A1A"
                app:strokeWidth="1dp"
                app:strokeColor="#44FFD700">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="📱"
                        android:textSize="32sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="摇一摇"
                            android:textSize="18sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="摇摇手机，接收来自星星的祝福"
                            android:textSize="13sp"
                            android:textColor="#99FFFFFF"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶"
                        android:textSize="24sp"
                        android:textColor="#FFD700" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 爱心吃豆 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_pacman_game"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#2A1A2A"
                app:strokeWidth="1dp"
                app:strokeColor="#44FF69B4">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="💝"
                        android:textSize="32sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="爱心吃豆"
                            android:textSize="18sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="收集星星，躲避云朵，满满的爱意"
                            android:textSize="13sp"
                            android:textColor="#99FFFFFF"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶"
                        android:textSize="24sp"
                        android:textColor="#FF69B4" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- 游戏容器 -->
    <FrameLayout
        android:id="@+id/game_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</FrameLayout>
