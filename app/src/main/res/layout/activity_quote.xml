<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_quote"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="invisible">

    <!-- 流转星空背景 -->
    <com.shortvideocleaner.app.StarryBackgroundView
        android:id="@+id/starry_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 前景内容 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 引言展示区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <ProgressBar
                android:id="@+id/progress_quote"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:visibility="gone"
                android:indeterminateTint="@color/primary" />

            <TextView
                android:id="@+id/tv_quote_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textColor="#E8E0D0"
                android:lineSpacingMultiplier="1.8"
                android:gravity="center"
                android:visibility="gone"
                android:textStyle="italic"
                android:shadowColor="#40FFFFFF"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="12" />

            <TextView
                android:id="@+id/tv_all_done"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="@color/success"
                android:gravity="center"
                android:visibility="gone"
                android:text="@string/all_done"
                android:shadowColor="#40FFFFFF"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="8" />

        </LinearLayout>

        <!-- 底部按钮区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:paddingBottom="48dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_next_quote"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:text="@string/btn_next"
                android:textSize="16sp"
                android:visibility="gone"
                app:backgroundTint="@color/primary"
                app:cornerRadius="26dp"
                style="@style/Widget.MaterialComponents.Button" />

            <TextView
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="← 回去"
                android:textSize="13sp"
                android:textColor="#99FFFFCC"
                android:visibility="gone" />

        </LinearLayout>
    </FrameLayout>
</FrameLayout>
